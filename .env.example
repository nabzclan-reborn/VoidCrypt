# VoidCrypt Configuration
# Copy this file to .env and fill in your values

#Dont forget to star the repo if you find it useful!!!

# =============================================================================
# REQUIRED - Get your key from: python3 voidcrypt.py --init
# =============================================================================
VOIDCRYPT_KEY=

# =============================================================================
# REQUIRED - Your upstream API key (lumyx AI, OpenAI, Anthropic, etc.)
# =============================================================================
PROVIDER_API_KEY=

# =============================================================================
# OPTIONAL - Upstream provider (default: lumyx AI)
# =============================================================================
UPSTREAM_PROVIDER_ENDPOINT=https://lumyx-ai.site/api

# =============================================================================
# OPTIONAL - Server settings
# =============================================================================
VOIDCRYPT_PORT=8400
VOIDCRYPT_DIR=~/.voidcrypt_nabzclan_vault

# =============================================================================
# OPTIONAL - Privacy level: paranoid | smart | minimal
#   paranoid: Encrypt ALL detected PII (names, emails, phones, etc.)
#   smart:    Encrypt critical PII only (SSN, API keys, passwords, etc.) [DEFAULT]
#   minimal:  Encrypt only credentials and secrets
# =============================================================================
VOIDCRYPT_LEVEL=smart

# =============================================================================
# OPTIONAL - Anonymization
# =============================================================================
# Tor SOCKS5h proxy for IP anonymization (requires Tor installed)
# VOIDCRYPT_TOR_PROXY=socks5h://localhost:9050

# Disable audit logging entirely
# VOIDCRYPT_ANONYMOUS=false

# Inject decoy noise to confuse provider-side analysis
# VOIDCRYPT_OBFUSCATE=false
